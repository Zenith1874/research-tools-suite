*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ── 备份 / 临时 ──
*.bak
*.bak-*
*.log
*.tmp

# ── Python ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

